# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Atlas Connection String
# Example:
# mongodb+srv://username:password@cluster0.xxxxxx.mongodb.net/travelgenie?retryWrites=true&w=majority
MONGO_URI=

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# SMTP (optional, but required to send real emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Allowed frontend origins (comma-separated)
# Expo local examples:
# http://localhost:8081,http://127.0.0.1:8081
CORS_ORIGINS=http://localhost:8081

# Optional static upload base URL (used when building public image URLs)
UPLOAD_BASE_URL=
