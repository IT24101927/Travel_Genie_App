# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Atlas Connection String
# Example:
# mongodb+srv://username:password@cluster0.xxxxxx.mongodb.net/travelgenie?retryWrites=true&w=majority
MONGO_URI=

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Allowed frontend origins (comma-separated)
# Expo local examples:
# http://localhost:8081,http://127.0.0.1:8081
CORS_ORIGINS=http://localhost:8081

# Optional static upload base URL (used when building public image URLs)
UPLOAD_BASE_URL=

# Optional AI service URL (Flask)
# Example: https://travelgenie-ai.up.railway.app
AI_SERVICE_URL=
