{
  "expo": {
    "name": "TravelGenie",
    "slug": "travelgenie-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f6f4ef"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {},
    "extra": {
      "apiBaseUrl": "http://10.0.2.2:5000/api/v1"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
